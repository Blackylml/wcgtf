generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Auth (NextAuth v5 / Auth.js) ───────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  role          Role      @default(USER)
  credits       Decimal   @default(0) @db.Decimal(10, 2)
  createdAt     DateTime  @default(now())

  accounts     Account[]
  sessions     Session[]
  groupBets    GroupBet[]
  matchBets    MatchBet[]
  bracketBets  BracketBet[]
  specialBets  SpecialBet[]
  payments     Payment[]
  jornadaReactions JornadaReaction[]
  koTiebreakers    KoTiebreaker[]
  creditTransactions CreditTransaction[]
  duelEntries        DuelEntry[]
  duelsAsUser1       DuelPair[] @relation("DuelPairUser1")
  duelsAsUser2       DuelPair[] @relation("DuelPairUser2")
  duelsWon           DuelPair[] @relation("DuelPairWinner")
  tiebreakerPicks    DuelTiebreakerPick[]
}

// Reacciones (boo / vamos) al ganador de una jornada. Una por usuario por jornada.
model JornadaReaction {
  id         String   @id @default(cuid())
  jornadaKey String   // "j1", "j2", "j3"
  userId     String
  type       String   // "boo" | "cheer"
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([jornadaKey, userId])
  @@index([jornadaKey])
}

enum Role {
  USER
  ADMIN
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Tournament ──────────────────────────────────────────────────────────────

model TournamentConfig {
  id                  String  @id @default(cuid())
  penaltiesAsDrawInKO Boolean @default(false) // admin toggle: penales = empate en eliminatorias
}

model Team {
  id    String  @id @default(cuid())
  name  String
  code  String  @unique // "MEX", "ARG", etc.
  flag  String?          // URL o emoji
  group String?          // "A" a "L"

  players     Player[]
  homeMatches Match[]    @relation("HomeTeam")
  awayMatches Match[]    @relation("AwayTeam")
  groupBets   GroupBet[]
}

// ─── Fase de Grupos ──────────────────────────────────────────────────────────

model GroupPool {
  id       String  @id @default(cuid())
  name     String  @unique // "A", "B", ... "L"
  isOpen   Boolean @default(false)
  price    Decimal @default(0) @db.Decimal(10, 2)

  bets GroupBet[]
}

model GroupBet {
  id          String   @id @default(cuid())
  userId      String
  groupPoolId String
  teamId      String
  position    Int      // 1, 2, 3, 4
  isCorrect   Boolean?
  createdAt   DateTime @default(now())

  user      User      @relation(fields: [userId], references: [id])
  groupPool GroupPool @relation(fields: [groupPoolId], references: [id])
  team      Team      @relation(fields: [teamId], references: [id])
  payment   Payment?  @relation(fields: [paymentId], references: [id])
  paymentId String?

  @@unique([userId, groupPoolId, teamId])
}

// ─── Partidos ─────────────────────────────────────────────────────────────────

model Match {
  id               String   @id @default(cuid())
  matchNumber      Int      @unique
  homeTeamId       String?
  awayTeamId       String?
  homeLabel        String?  // "1o Grupo A", "Ganador M74", etc.
  awayLabel        String?
  stage            Stage
  scheduledAt      DateTime
  venue            String?
  homeScore        Int?
  awayScore        Int?
  penaltiesAllowed Boolean  @default(false)
  penaltiesWinner  String?
  isOpen           Boolean  @default(false)
  price            Decimal  @default(0) @db.Decimal(10, 2)
  externalId       Int?     @unique // id del fixture en API-Football (para auto-resultados)

  homeTeam Team?      @relation("HomeTeam", fields: [homeTeamId], references: [id])
  awayTeam Team?      @relation("AwayTeam", fields: [awayTeamId], references: [id])
  bets     MatchBet[]
}

enum Stage {
  GROUP
  R32
  R16
  QF
  SF
  THIRD
  FINAL
  JORNADA  // Liga MX temporada regular
  LIG_QF   // Liga MX Liguilla — Cuartos de Final
  LIG_SF   // Liga MX Liguilla — Semifinales
  LIG_FINAL // Liga MX Liguilla — Final
}

model MatchBet {
  id            String    @id @default(cuid())
  userId        String
  matchId       String
  pick          MatchPick
  poolModule    Module?   // bolsa/quiniela a la que pertenece (permite picks independientes por bolsa)
  duelSessionId String?   // si != null, este pick es del duelo (no de la quiniela)
  isCorrect     Boolean?
  createdAt     DateTime  @default(now())

  user        User         @relation(fields: [userId], references: [id])
  match       Match        @relation(fields: [matchId], references: [id])
  payment     Payment?     @relation(fields: [paymentId], references: [id])
  paymentId   String?
  duelSession DuelSession? @relation(fields: [duelSessionId], references: [id])

  @@unique([userId, matchId, poolModule])
  @@unique([userId, matchId, duelSessionId])
}

enum MatchPick {
  HOME
  DRAW
  AWAY
}

// ─── Bracket Eliminatorias ───────────────────────────────────────────────────

model BracketSession {
  id      String  @id @default(cuid())
  isOpen  Boolean @default(false)
  price   Decimal @default(0) @db.Decimal(10, 2)
  config  Json?   // { "R32": [["MEX","USA"],["ARG","BRA"],...16 pairs] }

  bets BracketBet[]
}

model BracketBet {
  id               String   @id @default(cuid())
  userId           String
  bracketSessionId String
  predictions      Json     // { "R32_M1": "MEX", "R16_M1": "ARG", ... "FINAL": "BRA" }
  score            Int      @default(0)
  createdAt        DateTime @default(now())

  user    User           @relation(fields: [userId], references: [id])
  session BracketSession @relation(fields: [bracketSessionId], references: [id])
  payment Payment?       @relation(fields: [paymentId], references: [id])
  paymentId String?

  @@unique([userId, bracketSessionId])
}

// ─── Premios Especiales ───────────────────────────────────────────────────────

model Player {
  id     String @id @default(cuid())
  name   String
  teamId String

  team          Team         @relation(fields: [teamId], references: [id])
  specialBets   SpecialBet[]
  wonCategories SpecialPool[]

  @@unique([name, teamId])
}

model SpecialPool {
  id       String          @id @default(cuid())
  category SpecialCategory @unique
  price    Decimal         @default(0) @db.Decimal(10, 2)
  isOpen   Boolean         @default(false)
  winnerId String?

  winner Player?      @relation(fields: [winnerId], references: [id])
  bets   SpecialBet[]
}

model SpecialBet {
  id        String          @id @default(cuid())
  userId    String
  category  SpecialCategory
  playerId  String
  isCorrect Boolean?
  createdAt DateTime        @default(now())

  user      User        @relation(fields: [userId], references: [id])
  player    Player      @relation(fields: [playerId], references: [id])
  pool      SpecialPool @relation(fields: [category], references: [category])
  payment   Payment?    @relation(fields: [paymentId], references: [id])
  paymentId String?

  @@unique([userId, category])
}

enum SpecialCategory {
  TOP_SCORER
  BEST_PLAYER
  BEST_GOALKEEPER
  BEST_YOUNG_PLAYER
}

// ─── Pagos ────────────────────────────────────────────────────────────────────

model Payment {
  id             String        @id @default(cuid())
  userId         String
  module         Module?       // si != null, este pago es la ENTRADA a un módulo
  mpPaymentId    String?       @unique
  mpPreferenceId String?
  amount         Decimal       @db.Decimal(10, 2)
  status         PaymentStatus @default(PENDING)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  user        User         @relation(fields: [userId], references: [id])
  groupBets   GroupBet[]
  matchBets   MatchBet[]
  bracketBets BracketBet[]
  specialBets SpecialBet[]
  isCreditTopup Boolean    @default(false)
}

enum PaymentStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

// ─── Cobro por módulo ──────────────────────────────────────────────────────────
// Un solo precio por módulo. El usuario paga una vez (un Payment con `module`)
// y eso lo mete a la pool de ese módulo; sus apuestas suman al aprobarse el pago.

enum Module {
  GROUPS
  MATCHES
  MATCHES_G1
  MATCHES_G2
  MATCHES_G2B
  MATCHES_G3
  KO_R32
  KO_R16
  KO_QF
  KO_SF
  KO_FINAL
  BRACKET
  SPECIALS
  // Liga MX Apertura 2026 — Temporada regular (17 jornadas)
  LMX_J1
  LMX_J2
  LMX_J3
  LMX_J4
  LMX_J5
  LMX_J6
  LMX_J7
  LMX_J8
  LMX_J9
  LMX_J10
  LMX_J11
  LMX_J12
  LMX_J13
  LMX_J14
  LMX_J15
  LMX_J16
  LMX_J17
  // Liga MX Liguilla
  LMX_QF
  LMX_SF
  LMX_FINAL
}

model ModuleSettings {
  module    Module  @id
  price     Decimal @default(0) @db.Decimal(10, 2)
  entryOpen Boolean @default(true)
}

// ─── Desempate quinielas KO ───────────────────────────────────────────────────

// Predicciones de desempate del usuario para una quiniela KO.
model KoTiebreaker {
  id               String   @id @default(cuid())
  userId           String
  module           Module
  topScorerTeam    String?  // código del equipo más goleador predicho
  firstHalfGoals   Int?     // goles totales en 1er tiempo predichos
  earliestGoalTeam String?  // código del equipo con el gol más tempranero predicho
  updatedAt        DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([userId, module])
}

// Valores reales de la ronda (ingresados por el admin al terminar).
model KoRoundResult {
  module           Module  @id
  topScorerTeam    String? // equipo que más anotó en la ronda
  firstHalfGoals   Int?    // total de goles en 1er tiempo en la ronda
  earliestGoalTeam String? // equipo que anotó primero en la ronda
}

// ─── Créditos ────────────────────────────────────────────────────────────────

model CreditTransaction {
  id          String       @id @default(cuid())
  userId      String
  amount      Decimal      @db.Decimal(10, 2) // positivo = ingreso, negativo = gasto
  type        CreditTxType
  description String?
  refId       String?      // mpPaymentId, id de duel, nota admin, etc.
  createdAt   DateTime     @default(now())

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum CreditTxType {
  DEPOSIT_MP     // recarga vía MercadoPago
  DEPOSIT_ADMIN  // otorgado manualmente por admin
  SPEND_ENTRY    // usado para pagar entrada a un módulo/duelo
  REFUND         // devolución (ej: quedó sin pareja en 1v1)
  PRIZE_WIN      // ganó un duelo 1v1
}

// ─── Duelos 1v1 ──────────────────────────────────────────────────────────────

model DuelSession {
  id          String      @id @default(cuid())
  module      Module
  label       String      // ej. "Jornada 1 — 1v1"
  entryFee    Decimal     @db.Decimal(10, 2)
  houseCutPct Int         @default(10) // % que se queda la plataforma (0-100)
  isOpen      Boolean     @default(true)
  pairingDone Boolean     @default(false)
  createdAt   DateTime    @default(now())

  // ── Desempate (hasta 2 partidos, cada uno con HT+FT) ──────
  hasTiebreaker Boolean    @default(false)
  // Partido 1 (ej. Final del Mundial)
  tbHomeLabel   String?
  tbAwayLabel   String?
  tbDateLabel   String?
  tbHtResult    MatchPick?
  tbFtResult    MatchPick?
  // Partido 2 (ej. Chivas vs Toluca)
  tb2HomeLabel  String?
  tb2AwayLabel  String?
  tb2DateLabel  String?
  tb2HtResult   MatchPick?
  tb2FtResult   MatchPick?

  entries         DuelEntry[]
  pairs           DuelPair[]
  tiebreakerPicks DuelTiebreakerPick[]
  matchBets       MatchBet[]
}

model DuelTiebreakerPick {
  id        String      @id @default(cuid())
  sessionId String
  userId    String
  matchIdx  Int         @default(0) // 0 = partido 1, 1 = partido 2
  htPick    MatchPick
  ftPick    MatchPick
  createdAt DateTime    @default(now())

  session   DuelSession @relation(fields: [sessionId], references: [id])
  user      User        @relation(fields: [userId], references: [id])

  @@unique([sessionId, userId, matchIdx])
}

model DuelEntry {
  id          String      @id @default(cuid())
  sessionId   String
  userId      String
  paired      Boolean     @default(false)
  refunded    Boolean     @default(false)
  goalsGuess  Int?        // desempate: total de goles de la jornada
  createdAt   DateTime    @default(now())

  session   DuelSession @relation(fields: [sessionId], references: [id])
  user      User        @relation(fields: [userId], references: [id])

  @@unique([sessionId, userId])
}

model DuelPair {
  id         String      @id @default(cuid())
  sessionId  String
  user1Id    String
  user2Id    String
  prizePool  Decimal     @db.Decimal(10, 2) // lo que recibirá el ganador (ya descontado el corte)
  score1     Int?        // puntos de user1
  score2     Int?        // puntos de user2
  winnerId   String?
  prizeGiven Boolean     @default(false)
  createdAt  DateTime    @default(now())

  session    DuelSession @relation(fields: [sessionId], references: [id])
  user1      User        @relation("DuelPairUser1", fields: [user1Id], references: [id])
  user2      User        @relation("DuelPairUser2", fields: [user2Id], references: [id])
  winner     User?       @relation("DuelPairWinner", fields: [winnerId], references: [id])
}
